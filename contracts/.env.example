# 部署者私钥（带 0x 前缀）
# 本地测试可使用 Anvil 默认私钥: 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
PRIVATE_KEY=

# 代币初始供应量（不含精度，合约会自动乘以 10^18）
INITIAL_SUPPLY=1000000000

# Sepolia 测试网 RPC URL
# 可从 Alchemy、Infura、Chainstack 等服务商获取
SEPOLIA_RPC_URL=

# Etherscan API Key（用于合约验证）
# 从 https://etherscan.io/myapikey 获取
ETHERSCAN_API_KEY=